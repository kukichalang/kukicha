# doReady lists issues ready to work on (open + not blocked).
func doReady(args cli.Args)
    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    issues := listReady(pool, 50) onerr
        errPrint("cannot list ready issues: {error}")
        return

    if cli.IsJSON(args)
        printJSON(issues)
    else
        print(color.Bold("Ready to work on:"))
        printIssueList(issues)

# doBlocked lists issues that are blocked.
func doBlocked(args cli.Args)
    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    blocked := listBlocked(pool) onerr
        errPrint("cannot list blocked: {error}")
        return

    if cli.IsJSON(args)
        printJSON(blocked)
        return

    if len(blocked) equals 0
        print(color.Dim("  No blocked issues."))
        return

    print(color.Bold("Blocked issues:"))
    for b in blocked
        print("  {color.Bold(b.IssueId)} {b.Title}")
        print("    blocked by {color.Dim(b.BlockerId)} {color.Dim(b.BlockerTitle)}")

# doDep handles dep add/remove/list subcommands.
func doDep(args cli.Args)
    # Sub-subcommand dispatch via os.Args
    osArgs := os.Args
    if len(osArgs) < 3
        errPrint("usage: bd dep <add|remove|list> [flags]")
        return

    sub := osArgs[2]
    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    if sub equals "add"
        issueId := cli.GetString(args, "issue")
        dependsOn := cli.GetString(args, "depends-on")
        if issueId equals "" or dependsOn equals ""
            errPrint("usage: bd dep add --issue <id> --depends-on <id> [--type blocks]")
            return
        depTypeStr := cli.GetString(args, "dep-type")
        dt := DepBlocks
        if depTypeStr isnt ""
            dt = stringToDepType(depTypeStr)
            if dt equals -1
                dt = DepBlocks
        addDep(pool, issueId, dependsOn, dt) onerr
            errPrint("cannot add dependency: {error}")
            return

        print(color.Green("Added dependency: {issueId} depends on {dependsOn}"))
        return

    if sub equals "remove"
        issueId := cli.GetString(args, "issue")
        dependsOn := cli.GetString(args, "depends-on")
        if issueId equals "" or dependsOn equals ""
            errPrint("usage: bd dep remove --issue <id> --depends-on <id>")
            return
        removeDep(pool, issueId, dependsOn) onerr
            errPrint("cannot remove dependency: {error}")
            return

        print(color.Green("Removed dependency"))
        return

    if sub equals "list"
        issueId := cli.GetString(args, "issue")
        if issueId equals ""
            errPrint("usage: bd dep list --issue <id>")
            return
        deps := listDeps(pool, issueId) onerr
            errPrint("cannot list dependencies: {error}")
            return

        if cli.IsJSON(args)
            printJSON(deps)
            return
        if len(deps) equals 0
            print(color.Dim("  No dependencies."))
            return
        for d in deps
            if d.IssueId equals issueId
                print("  {d.IssueId} -> {d.DependsOnId} ({depTypeName(d.DepType)})")
            else
                print("  {d.DependsOnId} <- {d.IssueId} ({depTypeName(d.DepType)})")
        return

    errPrint("unknown dep subcommand: {sub}")

# doLabel handles label add/remove subcommands.
func doLabel(args cli.Args)
    osArgs := os.Args
    if len(osArgs) < 3
        errPrint("usage: bd label <add|remove> --id <id> --label <label>")
        return

    sub := osArgs[2]
    id := cli.GetString(args, "id")
    label := cli.GetString(args, "label")
    if id equals "" or label equals ""
        errPrint("--id and --label are required")
        return

    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    if sub equals "add"
        addLabel(pool, id, label) onerr
            errPrint("cannot add label: {error}")
            return

        print(color.Green("Added label '{label}' to {id}"))
        return

    if sub equals "remove"
        removeLabel(pool, id, label) onerr
            errPrint("cannot remove label: {error}")
            return

        print(color.Green("Removed label '{label}' from {id}"))
        return

    errPrint("unknown label subcommand: {sub}")

# doComment handles comment add/list subcommands.
func doComment(args cli.Args)
    osArgs := os.Args
    if len(osArgs) < 3
        errPrint("usage: bd comment <add|list> [flags]")
        return

    sub := osArgs[2]
    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    if sub equals "add"
        issueId := cli.GetString(args, "id")
        body := cli.GetString(args, "body")
        author := cli.GetString(args, "author")
        if issueId equals "" or body equals ""
            errPrint("--id and --body are required")
            return
        addComment(pool, issueId, body, author) onerr
            errPrint("cannot add comment: {error}")
            return

        print(color.Green("Comment added to {issueId}"))
        return

    if sub equals "list"
        issueId := cli.GetString(args, "id")
        if issueId equals ""
            errPrint("--id is required")
            return
        comments := listComments(pool, issueId) onerr
            errPrint("cannot list comments: {error}")
            return

        if cli.IsJSON(args)
            printJSON(comments)
            return
        if len(comments) equals 0
            print(color.Dim("  No comments."))
            return
        for c in comments
            author := c.Author
            if author equals ""
                author = "anonymous"
            print("  {color.Dim(timeAgo(c.CreatedAt))} {color.Dim("by")} {author}")
            print("    {c.Body}")
        return

    errPrint("unknown comment subcommand: {sub}")

# doSearch searches issues by title/description.
func doSearch(args cli.Args)
    query := cli.GetString(args, "query")
    if query equals ""
        errPrint("--query is required")
        return

    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    issues := searchIssues(pool, query, 50) onerr
        errPrint("cannot search: {error}")
        return

    if cli.IsJSON(args)
        printJSON(issues)
    else
        print(color.Bold("Search results for \"{query}\":"))
        printIssueList(issues)

# doStats shows aggregate statistics.
func doStats(args cli.Args)
    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    total := db.Count(pool, "SELECT COUNT(*) FROM issues") onerr
        errPrint("cannot count: {error}")
        return

    if cli.IsJSON(args)
        statusStats := getStatusStats(pool) onerr
            errPrint("{error}")
            return

        priStats := getPriorityStats(pool) onerr
            errPrint("{error}")
            return

        typeStats := getTypeStats(pool) onerr
            errPrint("{error}")
            return

        result := map of string to any{
            "total": total,
            "by_status": statusStats,
            "by_priority": priStats,
            "by_type": typeStats,
        }
        printJSON(result)
        return

    print(color.Bold("Issue Statistics"))
    print("  total: {total}")
    print("")

    statusStats := getStatusStats(pool) onerr
        errPrint("{error}")
        return

    print("  {color.Bold("By status:")}")
    for s in statusStats
        print("    {strpkg.PadRight(s.Label, 14, " ")} {s.Count}")

    print("")
    priStats := getPriorityStats(pool) onerr
        errPrint("{error}")
        return

    print("  {color.Bold("By priority:")}")
    for p in priStats
        print("    {strpkg.PadRight(p.Label, 14, " ")} {p.Count}")

    print("")
    typeStats := getTypeStats(pool) onerr
        errPrint("{error}")
        return

    print("  {color.Bold("By type:")}")
    for t in typeStats
        print("    {strpkg.PadRight(t.Label, 14, " ")} {t.Count}")
