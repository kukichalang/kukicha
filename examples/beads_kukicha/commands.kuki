# beads_kukicha — CLI command handlers
# Each doXxx function bridges CLI args to store operations and formatting.

petiole main

import "os"
import "stdlib/cli"
import "stdlib/color"
import "stdlib/db"
import "stdlib/json" as jsonpkg
import "stdlib/slice"
import "stdlib/string" as strpkg

# doInit initializes the beads database.
func doInit(args cli.Args)
    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    initDB(pool) onerr
        errPrint("cannot initialize schema: {error}")
        return

    if cli.IsJSON(args)
        printJSON(map of string to string{"status": "initialized", "db": dbPath})
    else
        print(color.Green("Initialized beads database at {dbPath}"))

# doCreate creates a new issue.
func doCreate(args cli.Args)
    title := cli.GetString(args, "title")
    if title equals ""
        errPrint("--title is required")
        return

    desc := cli.GetString(args, "description")
    typStr := cli.GetString(args, "type")
    priStr := cli.GetString(args, "priority")
    assignee := cli.GetString(args, "assignee")
    labelsStr := cli.GetString(args, "labels")

    issueType := stringToType(typStr)
    if issueType equals -1
        issueType = TypeTask

    priority := stringToPriority(priStr)
    if priority equals -1
        priority = PriorityMedium

    # Build JSON array from comma-separated labels
    labelsJSON := "[]"
    if labelsStr isnt ""
        parts := strpkg.Split(labelsStr, ",")
            |> slice.Map((p string) => strpkg.TrimSpace(p))
        bytes := jsonpkg.Marshal(parts) onerr
            errPrint("cannot build labels: {error}")
            return
        labelsJSON = bytes as string

    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    issue := createIssue(pool, title, desc, issueType, priority, assignee, labelsJSON) onerr
        errPrint("cannot create issue: {error}")
        return

    if cli.IsJSON(args)
        printJSON(issue)
    else
        print("{color.Green("Created")} {color.Bold(issue.Id)}  {issue.Title}")

# doList lists issues with optional filters.
func doList(args cli.Args)
    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    statusFilter := -1
    statusStr := cli.GetString(args, "status")
    if statusStr isnt ""
        statusFilter = stringToStatus(statusStr)

    priorityFilter := -1
    priStr := cli.GetString(args, "priority")
    if priStr isnt ""
        priorityFilter = stringToPriority(priStr)

    typeFilter := -1
    typStr := cli.GetString(args, "type")
    if typStr isnt ""
        typeFilter = stringToType(typStr)

    assignee := cli.GetString(args, "assignee")
    label := cli.GetString(args, "label")

    issues := listIssues(pool, statusFilter, priorityFilter, typeFilter, assignee, label, 100) onerr
        errPrint("cannot list issues: {error}")
        return

    if cli.IsJSON(args)
        printJSON(issues)
    else
        printIssueList(issues)

# doShow displays a single issue with its deps and comments.
func doShow(args cli.Args)
    id := cli.GetString(args, "id")
    if id equals ""
        errPrint("--id is required")
        return

    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    issue := getIssue(pool, id) onerr
        errPrint("issue not found: {error}")
        return

    if cli.IsJSON(args)
        printJSON(issue)
        return

    printIssue(issue)

    # Show dependencies
    deps := listDeps(pool, id) onerr
        return

    if len(deps) > 0
        print("")
        print("  {color.Bold("Dependencies:")}")
        for d in deps
            if d.IssueId equals id
                print("    depends on {d.DependsOnId} ({depTypeName(d.DepType)})")
            else
                print("    blocks {d.IssueId} ({depTypeName(d.DepType)})")

    # Show comments
    comments := listComments(pool, id) onerr
        return

    if len(comments) > 0
        print("")
        print("  {color.Bold("Comments:")}")
        for c in comments
            author := c.Author
            if author equals ""
                author = "anonymous"
            print("    {color.Dim(timeAgo(c.CreatedAt))} {color.Dim("by")} {author}")
            print("      {c.Body}")

# doUpdate updates fields on an issue.
func doUpdate(args cli.Args)
    id := cli.GetString(args, "id")
    if id equals ""
        errPrint("--id is required")
        return

    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    title := cli.GetString(args, "title")
    if title isnt ""
        updateIssueTitle(pool, id, title) onerr
            errPrint("cannot update title: {error}")
            return

    desc := cli.GetString(args, "description")
    if desc isnt ""
        updateIssueDesc(pool, id, desc) onerr
            errPrint("cannot update description: {error}")
            return

    priStr := cli.GetString(args, "priority")
    if priStr isnt ""
        pri := stringToPriority(priStr)
        if pri isnt -1
            updateIssuePriority(pool, id, pri) onerr
                errPrint("cannot update priority: {error}")
                return

    assignee := cli.GetString(args, "assignee")
    if assignee isnt ""
        updateIssueAssignee(pool, id, assignee) onerr
            errPrint("cannot update assignee: {error}")
            return

    statusStr := cli.GetString(args, "status")
    if statusStr isnt ""
        s := stringToStatus(statusStr)
        if s isnt -1
            updateIssueStatus(pool, id, s) onerr
                errPrint("cannot update status: {error}")
                return

    if cli.IsJSON(args)
        issue := getIssue(pool, id) onerr
            errPrint("{error}")
            return

        printJSON(issue)
    else
        print(color.Green("Updated {id}"))

# doClose closes an issue.
func doClose(args cli.Args)
    id := cli.GetString(args, "id")
    if id equals ""
        errPrint("--id is required")
        return

    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    closeIssue(pool, id) onerr
        errPrint("cannot close: {error}")
        return

    if cli.IsJSON(args)
        issue := getIssue(pool, id) onerr
            errPrint("{error}")
            return

        printJSON(issue)
    else
        print(color.Green("Closed {id}"))

