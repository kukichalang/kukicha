# doDelete deletes an issue permanently.
func doDelete(args cli.Args)
    id := cli.GetString(args, "id")
    if id equals ""
        errPrint("--id is required")
        return

    dbPath := cli.GetString(args, "db")
    pool := openDB(dbPath) onerr
        errPrint("cannot open database: {error}")
        return

    defer db.Close(pool)

    deleteIssue(pool, id) onerr
        errPrint("cannot delete: {error}")
