# beads_kukicha — display formatting helpers

petiole main

import "stdlib/cli"
import "stdlib/color"
import "stdlib/datetime"
import "stdlib/json" as jsonpkg
import "stdlib/string" as strpkg
import "time"

# --- Enum name converters ---

func statusName(s int) string
    if s equals StatusOpen
        return "open"
    if s equals StatusInProgress
        return "in-progress"
    if s equals StatusBlocked
        return "blocked"
    if s equals StatusClosed
        return "closed"
    return "unknown"

func statusColor(s int) string
    name := statusName(s)
    if s equals StatusOpen
        return color.Green(name)
    if s equals StatusInProgress
        return color.Cyan(name)
    if s equals StatusBlocked
        return color.Red(name)
    if s equals StatusClosed
        return color.Dim(name)
    return name

func stringToStatus(s string) int
    if s equals "open"
        return StatusOpen
    if s equals "in-progress" or s equals "in_progress" or s equals "inprogress"
        return StatusInProgress
    if s equals "blocked"
        return StatusBlocked
    if s equals "closed"
        return StatusClosed
    return -1

func priorityName(p int) string
    if p equals PriorityCritical
        return "critical"
    if p equals PriorityHigh
        return "high"
    if p equals PriorityMedium
        return "medium"
    if p equals PriorityLow
        return "low"
    if p equals PriorityBacklog
        return "backlog"
    return "unknown"

func priorityColor(p int) string
    name := priorityName(p)
    if p equals PriorityCritical
        return color.Error(name)
    if p equals PriorityHigh
        return color.Red(name)
    if p equals PriorityMedium
        return color.Yellow(name)
    if p equals PriorityLow
        return color.Blue(name)
    if p equals PriorityBacklog
        return color.Dim(name)
    return name

func stringToPriority(s string) int
    if s equals "critical" or s equals "0"
        return PriorityCritical
    if s equals "high" or s equals "1"
        return PriorityHigh
    if s equals "medium" or s equals "2"
        return PriorityMedium
    if s equals "low" or s equals "3"
        return PriorityLow
    if s equals "backlog" or s equals "4"
        return PriorityBacklog
    return -1

func typeName(t int) string
    if t equals TypeTask
        return "task"
    if t equals TypeBug
        return "bug"
    if t equals TypeFeature
        return "feature"
    if t equals TypeEpic
        return "epic"
    if t equals TypeChore
        return "chore"
    return "unknown"

func stringToType(s string) int
    if s equals "task"
        return TypeTask
    if s equals "bug"
        return TypeBug
    if s equals "feature"
        return TypeFeature
    if s equals "epic"
        return TypeEpic
    if s equals "chore"
        return TypeChore
    return -1

func depTypeName(d int) string
    if d equals DepBlocks
        return "blocks"
    if d equals DepRelated
        return "related"
    if d equals DepParentChild
        return "parent-child"
    return "unknown"

func stringToDepType(s string) int
    if s equals "blocks"
        return DepBlocks
    if s equals "related"
        return DepRelated
    if s equals "parent-child" or s equals "parent_child"
        return DepParentChild
    return -1

# --- Time formatting ---

func nowISO() string
    return datetime.Format(datetime.Now(), "datetime")

func timeAgo(iso string) string
    t := datetime.Parse(iso, "datetime") onerr return iso
    diff := time.Since(t)
    secs := diff.Seconds() as int64
    if secs < 60
        return "just now"
    mins := secs / 60
    if mins < 60
        return "{mins}m ago"
    hours := mins / 60
    if hours < 24
        return "{hours}h ago"
    days := hours / 24
    if days < 30
        return "{days}d ago"
    months := days / 30
    return "{months}mo ago"

# --- Display helpers ---

func printIssue(issue Issue)
    print("{color.Bold(issue.Id)}  {issue.Title}")
    print("  status:   {statusColor(issue.Status)}")
    print("  priority: {priorityColor(issue.Priority)}")
    print("  type:     {typeName(issue.IssueType)}")
    if issue.Assignee isnt ""
        print("  assignee: {issue.Assignee}")
    if issue.Labels isnt "[]" and issue.Labels isnt ""
        print("  labels:   {issue.Labels}")
    if issue.Description isnt ""
        print("  desc:     {issue.Description}")
    print("  created:  {timeAgo(issue.CreatedAt)} {color.Dim("({issue.CreatedAt})")}")
    if issue.UpdatedAt isnt issue.CreatedAt
        print("  updated:  {timeAgo(issue.UpdatedAt)}")
    if issue.ClosedAt isnt ""
        print("  closed:   {timeAgo(issue.ClosedAt)}")
    print("  hash:     {color.Dim(issue.ContentHash[:16])}")

func printIssueRow(issue Issue)
    id := strpkg.PadRight(issue.Id, 14, " ")
    typ := strpkg.PadRight(typeName(issue.IssueType), 9, " ")
    age := strpkg.PadRight(timeAgo(issue.CreatedAt), 10, " ")
    title := issue.Title
    if len(title) > 50
        title = title[:47] + "..."
    print(
        "  {color.Dim(id)} {statusColor(issue.Status)} {priorityColor(issue.Priority)} {color.Dim(typ)} {color.Dim(age)} {title}",
    )

func printIssueList(issues list of Issue)
    if len(issues) equals 0
        print(color.Dim("  No issues found."))
        return
    header := strpkg.PadRight("  ID", 16, " ") + strpkg.PadRight("STATUS", 14, " ") + strpkg.PadRight("PRI", 12, " ") + strpkg.PadRight("TYPE", 11, " ") + strpkg.PadRight("AGE", 12, " ") + "TITLE"
    print(color.Dim(header))
    for issue in issues
        printIssueRow(issue)

func printJSON(v any)
    data := jsonpkg.MarshalPretty(v) onerr
        cli.Error("json error: {error}")
        return

    print(data as string)

func errPrint(msg string)
    cli.Error("{color.Red("error:")} {msg}")
