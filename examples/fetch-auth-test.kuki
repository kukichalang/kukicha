import "time"
import "net/http"
import "stdlib/fetch"

# Start a local server to test against
func startServer()
    http.HandleFunc("/bearer", func(w http.ResponseWriter, r reference http.Request)
        auth := r.Header.Get("Authorization")
        if auth == "Bearer my-secret-token"
            w.Write("OK" as list of byte)
        else
            w.WriteHeader(401)
            w.Write("Unauthorized" as list of byte)
    )

    http.HandleFunc("/basic", func(w http.ResponseWriter, r reference http.Request)
        auth := r.Header.Get("Authorization")
        # "user:pass" base64 encoded is "dXNlcjpwYXNz"
        if auth == "Basic dXNlcjpwYXNz"
            w.Write("OK" as list of byte)
        else
            w.WriteHeader(401)
            w.Write("Unauthorized" as list of byte)
    )

    http.HandleFunc("/form", func(w http.ResponseWriter, r reference http.Request)
        if r.Method != "POST"
            w.WriteHeader(405)
            return

        ct := r.Header.Get("Content-Type")
        if ct != "application/x-www-form-urlencoded"
            w.WriteHeader(400)
            w.Write("Bad Content-Type" as list of byte)
            return

        r.ParseForm()
        val := r.Form.Get("hello")
        if val == "world"
            w.Write("OK" as list of byte)
        else
            w.WriteHeader(400)
            w.Write("Bad Form Value" as list of byte)
    )

    http.HandleFunc("/session", func(w http.ResponseWriter, r reference http.Request)
        if cookie, err := r.Cookie("mysession"); err != empty
            # Cookie is not present, set it
            http.SetCookie(w, reference of http.Cookie{Name: "mysession", Value: "active"})
            w.Write("Cookie Set" as list of byte)
        else
            # Cookie is present
            if cookie.Value == "active"
                w.Write("Cookie Present" as list of byte)
            else
                w.WriteHeader(400)
                w.Write("Bad Cookie" as list of byte)
    )

    print("Server listening on :8099")
    http.ListenAndServe(":8099", empty)

func main()
    # Start server in background
    go startServer()

    # Wait for server to start
    time.Sleep(200 * time.Millisecond)

    baseUrl := "http://localhost:8099"

    # 1. Test Bearer Auth
    print("\n--- Testing Bearer Auth ---")
    resp1 := fetch.New("{baseUrl}/bearer") |> fetch.BearerAuth("my-secret-token") |> fetch.Do() onerr panic "Bearer request failed: {error}"
    text1 := fetch.Text(resp1) onerr panic "Text read failed: {error}"
    print("Response: {text1}")
    if text1 != "OK"
        panic("Bearer auth failed")

    # 2. Test Basic Auth
    print("\n--- Testing Basic Auth ---")
    resp2 := fetch.New("{baseUrl}/basic") |> fetch.BasicAuth("user", "pass") |> fetch.Do() onerr panic "Basic request failed: {error}"
    text2 := fetch.Text(resp2) onerr panic "Text read failed: {error}"
    print("Response: {text2}")
    if text2 != "OK"
        panic("Basic auth failed")

    # 3. Test Form Data
    print("\n--- Testing Form Data ---")
    data := map of string to string{"hello": "world"}
    resp3 := fetch.New("{baseUrl}/form") |> fetch.FormData(data) |> fetch.Method("POST") |> fetch.Do() onerr panic "Form request failed: {error}"
    text3 := fetch.Text(resp3) onerr panic "Text read failed: {error}"
    print("Response: {text3}")
    if text3 != "OK"
        panic("Form data failed")

    # 4. Test Session
    print("\n--- Testing Session ---")
    session := fetch.NewSession()

    # First request: should set cookie
    resp4a := fetch.SessionGet(session, "{baseUrl}/session") onerr panic "Session request 1 failed: {error}"
    text4a := fetch.Text(resp4a) onerr panic "Text read failed: {error}"
    print("Request 1: {text4a}")

    # Second request: should send cookie
    resp4b := fetch.SessionGet(session, "{baseUrl}/session") onerr panic "Session request 2 failed: {error}"
    text4b := fetch.Text(resp4b) onerr panic "Text read failed: {error}"
    print("Request 2: {text4b}")

    if text4b != "Cookie Present"
        panic("Session cookie persistence failed")

    print("\nAll tests passed successfully!")
