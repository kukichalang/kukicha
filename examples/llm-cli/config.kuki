# Config — loads settings from file + environment variables
# Priority: env vars > config file > defaults

petiole main

import "os"
import "path/filepath"
import "stdlib/env"
import "stdlib/files"
import "stdlib/json" as jsonpkg

type Config
    WebUIURL string json:"webui_url"
    WebUIAPIKey string json:"webui_api_key"
    Model string json:"model"
    TerminalMCPURL string json:"terminal_mcp_url"
    MaxToolRounds int json:"max_tool_rounds"

func defaultConfigPath() string
    home, _ := os.UserHomeDir()
    return filepath.Join(home, ".config", "owui", "config.json")

func loadConfig() Config
    cfg := Config{
        WebUIURL: "http://localhost:3000",
        TerminalMCPURL: "http://localhost:8000/mcp",
        Model: "llama3.1",
        MaxToolRounds: 15,
    }

    # Try loading from config file
    data := files.ReadString(defaultConfigPath()) onerr ""
    if data isnt ""
        jsonpkg.UnmarshalString(data, reference of cfg) onerr discard

    # Environment variables override file settings
    v := env.GetOr("OWUI_WEBUI_URL", "")
    if v isnt ""
        cfg.WebUIURL = v

    v = env.GetOr("OWUI_WEBUI_API_KEY", "")
    if v isnt ""
        cfg.WebUIAPIKey = v

    v = env.GetOr("OWUI_MODEL", "")
    if v isnt ""
        cfg.Model = v

    v = env.GetOr("OWUI_TERMINAL_MCP_URL", "")
    if v isnt ""
        cfg.TerminalMCPURL = v

    return cfg

func saveConfig(cfg Config) error
    path := defaultConfigPath()
    os.MkdirAll(filepath.Dir(path), 0700) onerr return error "{error}"
    data := jsonpkg.MarshalPretty(cfg) onerr return
    files.Write(data as string, path) onerr return
    return empty

func validateConfig(cfg Config) error
    if cfg.WebUIAPIKey equals ""
        return error "Open WebUI API key required: set OWUI_WEBUI_API_KEY or run `owui configure`"
    return empty
