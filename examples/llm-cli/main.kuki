# owui — CLI agent: Open WebUI + Open Terminal via MCP
# Dispatches subcommands manually since the root command accepts
# arbitrary args as a prompt (models/tools/health/configure/version
# are subcommands, everything else is treated as a prompt)

petiole main

import "context"
import "fmt"
import "io"
import "os"
import "stdlib/fetch"
import "stdlib/input"
import "stdlib/json" as jsonpkg
import "stdlib/string" as strpkg

variable version string = "dev"

# ANSI formatting helpers
constant ansiReset = "\033[0m"
constant ansiDim = "\033[2m"
constant ansiYellow = "\033[33m"
constant ansiBoldYellow = "\033[1;33m"
constant ansiBoldCyan = "\033[1;36m"
constant ansiRed = "\033[91m"
constant ansiGreen = "\033[32m"

func dimFmt(s string) string
    return "{ansiDim}{s}{ansiReset}"

func toolFmt(s string) string
    return "{ansiYellow}{s}{ansiReset}"

func errFmt(s string) string
    return "{ansiRed}{s}{ansiReset}"

func greenFmt(s string) string
    return "{ansiGreen}{s}{ansiReset}"

func boldCyanFmt(s string) string
    return "{ansiBoldCyan}{s}{ansiReset}"

func boldYellowFmt(s string) string
    return "{ansiBoldYellow}{s}{ansiReset}"

# ---- Entrypoint ----

func main()
    args := os.Args[1:]

    # Parse flags from args, separating them from positional args
    flagModel := ""
    flagChat := false
    flagRaw := false
    flagSystem := ""
    positional := make(list of string, 0)

    i := 0
    for i < len(args)
        arg := args[i]
        if arg == "-m" or arg == "--model"
            i = i + 1
            if i < len(args)
                flagModel = args[i]
        else if strpkg.HasPrefix(arg, "--model=")
            flagModel = strpkg.TrimPrefix(arg, "--model=")
        else if arg == "-c" or arg == "--chat"
            flagChat = true
        else if arg == "--raw"
            flagRaw = true
        else if arg == "-S" or arg == "--system"
            i = i + 1
            if i < len(args)
                flagSystem = args[i]
        else if strpkg.HasPrefix(arg, "--system=")
            flagSystem = strpkg.TrimPrefix(arg, "--system=")
        else if arg == "-h" or arg == "--help"
            printUsage()
            return
        else
            positional = append(positional, arg)
        i = i + 1

    # Dispatch subcommands
    if len(positional) > 0
        cmd := positional[0]
        if cmd == "models"
            err := cmdListModels()
            if err != empty
                fmt.Fprintln(os.Stderr, errFmt("error: {err}"))
                os.Exit(1)
            return
        if cmd == "tools"
            err := cmdListTools()
            if err != empty
                fmt.Fprintln(os.Stderr, errFmt("error: {err}"))
                os.Exit(1)
            return
        if cmd == "health"
            err := cmdHealth()
            if err != empty
                fmt.Fprintln(os.Stderr, errFmt("error: {err}"))
                os.Exit(1)
            return
        if cmd == "configure"
            err := cmdConfigure()
            if err != empty
                fmt.Fprintln(os.Stderr, errFmt("error: {err}"))
                os.Exit(1)
            return
        if cmd == "version"
            print("owui {version}")
            return

    # Default: agent mode
    err := cmdRun(positional, flagModel, flagChat, flagRaw, flagSystem)
    if err != empty
        fmt.Fprintln(os.Stderr, errFmt("error: {err}"))
        os.Exit(1)

# ---- Agent mode ----

func cmdRun(positional list of string, flagModel string, flagChat bool, flagRaw bool, flagSystem string) error
    cfg := loadConfig()
    if flagModel != ""
        cfg.Model = flagModel
    validateConfig(cfg) onerr return

    ctx := context.Background()

    bridge := connectBridge(ctx, cfg.TerminalMCPURL) onerr return empty, error "connecting to Open Terminal MCP: {error}"
    defer closeBridge(bridge)

    if isTTYErr()
        fmt.Fprintf(os.Stderr, "{dimFmt("MCP connected:")} {dimFmt("{bridgeToolCount(bridge)} tools from {cfg.TerminalMCPURL}")}\n")

    a := reference of Agent{
        Bridge: bridge,
        Config: cfg,
        MaxRounds: cfg.MaxToolRounds,
    }
    if flagSystem != ""
        a.SystemPrompt = flagSystem

    prompt := gatherPrompt(positional)

    # Interactive chat
    if flagChat
        runChat(ctx, a, prompt)
        return empty

    # Pipe / one-shot
    if prompt == ""
        return error "no prompt provided — use -c for interactive chat"

    isTTY := isTTYOut()

    if isTTY
        a.OnToolCall = func(name string, toolArgs string)
            fmt.Fprintf(os.Stderr, "{toolFmt("-> {name}")} {dimFmt(truncateFmt(toolArgs, 80))}\n")
        a.OnToolResult = func(name string, result string)
            fmt.Fprintf(os.Stderr, "{toolFmt("<- {name}")} {dimFmt(truncateFmt(result, 120))}\n")

    a.OnText = func(chunk string)
        if isTTY and not flagRaw
            fmt.Print(chunk)

    result := runAgent(ctx, a, prompt, empty list of llm.Message) onerr return

    if isTTY and not flagRaw
        fmt.Println()
    else
        fmt.Print(result.Content)

    if isTTY
        fmt.Fprintf(os.Stderr, "{dimFmt("({result.Rounds} tool rounds)")}\n")

    return empty

# ---- Subcommands ----

type ModelEntry
    ID string json:"id"
    Name string json:"name"

type ModelsResponse
    Data list of ModelEntry json:"data"

func cmdListModels() error
    cfg := loadConfig()
    if cfg.WebUIAPIKey == ""
        return error "Open WebUI API key required"

    url := "{strpkg.TrimRight(cfg.WebUIURL, "/")}/api/models"
    resp := fetch.New(url)
        |> fetch.BearerAuth(cfg.WebUIAPIKey)
        |> fetch.Do() onerr return

    defer resp.Body.Close()

    if resp.StatusCode != 200
        body := fetch.Bytes(resp) onerr return empty, error "HTTP {resp.StatusCode}"
        return error "HTTP {resp.StatusCode}: {body as string}"

    models := ModelsResponse{}
    jsonpkg.UnmarshalRead(resp.Body, reference of models) onerr return

    print(boldCyanFmt("Available models:"))
    for _, m in models.Data
        name := m.Name
        if name == ""
            name = m.ID
        print("  {name} {dimFmt("({m.ID})")}")

    return empty

func cmdListTools() error
    cfg := loadConfig()
    ctx := context.Background()

    bridge := connectBridge(ctx, cfg.TerminalMCPURL) onerr return
    defer closeBridge(bridge)

    print(boldYellowFmt("Tools from {cfg.TerminalMCPURL}:"))
    for _, name in bridgeToolNames(bridge)
        print("  {name}")

    return empty

func cmdHealth() error
    cfg := loadConfig()
    ctx := context.Background()

    # Open WebUI
    fmt.Printf("Open WebUI  ({cfg.WebUIURL})  ")
    if cfg.WebUIAPIKey != ""
        url := "{strpkg.TrimRight(cfg.WebUIURL, "/")}/api/models"
        resp, err := fetch.New(url)
            |> fetch.BearerAuth(cfg.WebUIAPIKey)
            |> fetch.Do()
        if err != empty
            fmt.Println(errFmt("x"), err)
        else
            resp.Body.Close()
            if resp.StatusCode == 200
                fmt.Println(greenFmt("ok"))
            else
                fmt.Println(errFmt("x"), "HTTP {resp.StatusCode}")
    else
        fmt.Println(errFmt("x"), "no API key")

    # Open Terminal MCP
    fmt.Printf("Terminal MCP ({cfg.TerminalMCPURL})  ")
    bridge, err := connectBridge(ctx, cfg.TerminalMCPURL)
    if err != empty
        fmt.Println(errFmt("x"), err)
    else
        fmt.Println(greenFmt("ok"), "{bridgeToolCount(bridge)} tools")
        closeBridge(bridge)

    return empty

func cmdConfigure() error
    cfg := loadConfig()

    v := input.ReadLine("Open WebUI URL [{cfg.WebUIURL}]: ") onerr ""
    if v != ""
        cfg.WebUIURL = v

    v = input.ReadLine("Open WebUI API Key [{maskKey(cfg.WebUIAPIKey)}]: ") onerr ""
    if v != ""
        cfg.WebUIAPIKey = v

    v = input.ReadLine("Model [{cfg.Model}]: ") onerr ""
    if v != ""
        cfg.Model = v

    v = input.ReadLine("Open Terminal MCP URL [{cfg.TerminalMCPURL}]: ") onerr ""
    if v != ""
        cfg.TerminalMCPURL = v

    saveConfig(cfg) onerr return
    print(greenFmt("Saved to {defaultConfigPath()}"))
    return empty

# ---- Interactive chat (simple readline loop) ----

func runChat(ctx context.Context, a reference Agent, initialPrompt string)
    history := empty list of llm.Message
    prompt := initialPrompt

    print(dimFmt("owui chat — model: {a.Config.Model} — type 'exit' to quit"))
    print("")

    for
        if prompt == ""
            prompt = input.ReadLine(boldCyanFmt("you> ")) onerr break
            if prompt == "exit" or prompt == "quit"
                break
            if prompt == ""
                continue

        a.OnToolCall = func(name string, toolArgs string)
            fmt.Fprintf(os.Stderr, "  {toolFmt("-> {name}")} {dimFmt(truncateFmt(toolArgs, 60))}\n")
        a.OnToolResult = func(name string, result string)
            fmt.Fprintf(os.Stderr, "  {toolFmt("<- {name}")} {dimFmt(truncateFmt(result, 80))}\n")
        a.OnText = empty

        result := runAgent(ctx, a, prompt, history) onerr
            print(errFmt("error: {error}"))
            print("")
            prompt = ""
            continue

        print("")
        print("{dimFmt(a.Config.Model)}  {result.Content}")
        if result.Rounds > 1
            print(dimFmt("  ({result.Rounds} rounds)"))
        print("")

        history = result.Messages
        prompt = ""

# ---- Helpers ----

func gatherPrompt(args list of string) string
    prompt := ""

    stdinInfo, _ := os.Stdin.Stat()
    if (stdinInfo.Mode() & os.ModeCharDevice) == 0
        data := io.ReadAll(os.Stdin) onerr empty list of byte
        prompt = strpkg.TrimSpace(data as string)

    if len(args) > 0
        argText := strpkg.Join(args, " ")
        if prompt != ""
            prompt = "{argText}\n\n{prompt}"
        else
            prompt = argText

    return prompt

func isTTYOut() bool
    info, _ := os.Stdout.Stat()
    return (info.Mode() & os.ModeCharDevice) != 0

func isTTYErr() bool
    info, _ := os.Stderr.Stat()
    return (info.Mode() & os.ModeCharDevice) != 0

func maskKey(k string) string
    if len(k) < 8
        return "--------"
    return "{k[:4]}...{k[len(k)-4:]}"

func truncateFmt(s string, n int) string
    s = strpkg.Replace(s, "\n", " ")
    if len(s) <= n
        return s
    return "{s[:n]}..."

func printUsage()
    print("owui — CLI agent: Open WebUI models + Open Terminal via MCP")
    print("")
    print("Usage:")
    print("  owui [flags] [prompt]     Agent mode (one-shot or piped)")
    print("  owui -c [prompt]          Interactive chat")
    print("  owui models               List available models")
    print("  owui tools                List MCP tools")
    print("  owui health               Check connectivity")
    print("  owui configure            Save configuration")
    print("  owui version              Print version")
    print("")
    print("Flags:")
    print("  -m, --model <model>       Override model")
    print("  -c, --chat                Interactive chat mode")
    print("  -S, --system <prompt>     Override system prompt")
    print("  --raw                     Raw output (no formatting)")
    print("")
    print("Environment:")
    print("  OWUI_WEBUI_URL            Open WebUI URL (default: http://localhost:3000)")
    print("  OWUI_WEBUI_API_KEY        Open WebUI API key (required)")
    print("  OWUI_MODEL                Model name (default: llama3.1)")
    print("  OWUI_TERMINAL_MCP_URL     MCP URL (default: http://localhost:8000/mcp)")
