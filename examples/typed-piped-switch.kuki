# Example demonstrating typed piped switches (|> switch as v)
# Models LLM tool call results — each outcome carries different data

import "fmt"

enum ToolResult
    Success
        output string
    Error
        message string
        code int
    Timeout

type ToolRun
    name string
    result ToolResult

func summarize(run ToolRun) string
    return run.result |> switch as v
        when Success
            return fmt.Sprintf("%s: %s", run.name, v.output)
        when Error
            return fmt.Sprintf("%s: FAILED (%d) %s", run.name, v.code, v.message)
        when Timeout
            return fmt.Sprintf("%s: timed out", run.name)

func main()
    runs := list of ToolRun{ToolRun{name: "read_file", result: Success{output: "48 lines"}}, ToolRun{name: "exec", result: Error{message: "permission denied", code: 126}}, ToolRun{name: "web_search", result: Timeout{}}, ToolRun{name: "write_file", result: Success{output: "wrote config.yaml"}}}

    for run in runs
        print(summarize(run))
