# Changelog generator for Kukicha releases
# Uses Mistral (Chat Completions API) to generate/update CHANGELOG.md from git history.
# Also writes the new entry alone to changelog-entry.md for use as GitHub release notes.
#
# Usage:
#   kukicha run scripts/changelog.kuki [version] [--json]
#
# Examples:
#   kukicha run scripts/changelog.kuki v0.5.0         # specify version
#   kukicha run scripts/changelog.kuki                # auto-label as "Unreleased"
#   kukicha run scripts/changelog.kuki v0.5.0 --json  # agent-friendly output
#
# Prerequisites:
#   export MISTRAL_API_KEY="..."

import "fmt"
import "os"
import "stdlib/cli"
import "stdlib/files"
import "stdlib/json" as jsonpkg
import "stdlib/llm"
import "stdlib/semver"
import "stdlib/shell"
import "stdlib/slice"
import "stdlib/string" as strpkg

type ChangelogResult
    version string as "version"
    date string as "date"
    entry string as "entry"

func printJSON(v any)
    bytes := jsonpkg.MarshalPretty(v) onerr
        fmt.Fprintln(os.Stderr, "json marshal error: {error}")
        os.Exit(1)
    fmt.Println(string(bytes))

func main()
    _ = cli.New("changelog")
        |> cli.Description("Generate CHANGELOG.md entries from git history using an LLM")
        |> cli.Arg("version", "Release version (e.g. v0.5.0). Defaults to 'Unreleased'")
        |> cli.GlobalFlag("json", "Emit machine-readable JSON instead of progress prose", "false")
        |> cli.Action(run)
        |> cli.RunApp() onerr panic "{error}"

func run(args cli.Args)
    version := cli.GetString(args, "version")
    if version == ""
        version = "Unreleased"
    jsonOut := cli.GetBool(args, "json")
    generateChangelog(version, jsonOut)

func generateChangelog(version string, jsonOut bool)
    # Get sorted tag list and find the previous release tag using semver
    tagsRaw := shell.Output("git", "tag", "-l") onerr ""
    tagsRaw = strpkg.Trim(tagsRaw, "\n")
    tagLines := strpkg.Split(tagsRaw, "\n")
        |> slice.Filter((t string) => semver.Valid(t))

    # Sort by semver to find the two most recent tags
    lastTag := ""
    if slice.IsNotEmpty(tagLines)
        best := semver.Highest(tagLines) onerr ""
        if best == version and len(tagLines) > 1
            # Current version tag already exists — find the one before it
            remaining := tagLines |> slice.Filter((t string) => t != best)
            if slice.IsNotEmpty(remaining)
                lastTag = semver.Highest(remaining) onerr ""
        else
            lastTag = best

    # Get commits since previous tag (or last 50 if no prior tags exist)
    gitLog := ""
    if lastTag != ""
        rangeArg := "{lastTag}..HEAD"
        gitLog = shell.Output("git", "log", rangeArg, "--oneline", "--no-merges") onerr panic "git log failed: {error}"
    else
        gitLog = shell.Output("git", "log", "--oneline", "--no-merges", "-50") onerr panic "git log failed: {error}"

    gitLog = strpkg.Trim(gitLog, "\n")
    if gitLog == ""
        if jsonOut
            printJSON(map of string to string{"error": "no new commits since {lastTag}"})
            os.Exit(0)
        print("No new commits since {lastTag}. Nothing to add to CHANGELOG.md.")
        return

    # Determine the release date
    # Try to get the tagged commit date first; fall back to today's system date.
    # This prevents the LLM from hallucinating a date from its training data.
    releaseDate := ""
    if version != "Unreleased"
        tagDate := shell.Output("git", "log", "-1", "--format=%cs", version) onerr ""
        tagDate = strpkg.Trim(tagDate, "\n")
        if tagDate != ""
            releaseDate = tagDate
    if releaseDate == ""
        sysDate := shell.Output("date", "-u", "+%Y-%m-%d") onerr ""
        releaseDate = strpkg.Trim(sysDate, "\n")

    # Show what we're working with (suppressed in JSON mode)
    if not jsonOut
        if lastTag != ""
            print("Generating changelog for {version} ({releaseDate}) (commits since {lastTag})...")
        else
            print("Generating changelog for {version} ({releaseDate}) (no prior tags found, using last 50 commits)...")
        print("")
        print(gitLog)
        print("")

    # Read existing CHANGELOG.md if present
    existing := ""
    if files.Exists("CHANGELOG.md")
        rawBytes := files.Read("CHANGELOG.md") onerr panic "Failed to read CHANGELOG.md: {error}"
        existing = rawBytes as string

    # Build the prompt
    context := ""
    if lastTag != ""
        context = "Previous release tag: {lastTag}\n"

    prompt := "You are a changelog writer for Kukicha, a beginner-friendly programming language that transpiles to Go.\n\n{context}New commits to summarize:\n{gitLog}\n\nWrite a single CHANGELOG entry for version {version}.\n\nRules:\n- Start with exactly: ## [{version}] - {releaseDate}\n- Group changes under ### Added, ### Changed, ### Fixed, ### Security (only include sections that apply)\n- Write concise bullet points from the developer perspective\n- Each bullet point must end with a markdown link to the relevant commit(s), e.g. ([abc1234](https://github.com/duber000/kukicha/commit/abc1234)). Use the 7-character short hash from the commit log.\n- Skip trivial or internal-only changes\n- Output ONLY the markdown section starting with ##, no preamble or explanation"

    entry := llm.New("mistral:mistral-large-latest")
        |> llm.MaxTokens(2048)
        |> llm.Retry(3, 1000)
        |> llm.Ask(prompt)
        onerr panic "LLM call failed: {error}"

    # Build updated CHANGELOG.md
    header := "# Changelog\n\nAll notable changes to Kukicha will be documented in this file.\nThis file is auto-generated by `scripts/changelog.kuki`.\n\n"

    newContent := ""
    if existing == ""
        newContent = header + entry + "\n"
    else if strpkg.Contains(existing, "\n## ")
        # Splice new entry in after the file header, before the first ## section
        parts := strpkg.SplitN(existing, "\n## ", 2)
        newContent = parts[0] + "\n" + entry + "\n\n## " + parts[1]
    else
        newContent = existing + "\n" + entry + "\n"

    files.WriteString(newContent, "CHANGELOG.md") onerr panic "Failed to write CHANGELOG.md: {error}"
    files.WriteString(entry, "changelog-entry.md") onerr panic "Failed to write changelog-entry.md: {error}"

    if jsonOut
        printJSON(ChangelogResult{version: version, date: releaseDate, entry: entry})
        return

    print("CHANGELOG.md updated.")
    print("")
    print(entry)
