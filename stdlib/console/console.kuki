# Kukicha Standard Library - Console
# Helpers for printing to stdout and stderr.

petiole console

import "fmt"
import "os"

# Error prints a message to stderr.
# Example: console.Error("something went wrong: {error}")
func Error(msg string)
    fmt.Fprintln(os.Stderr, msg)

# Warn prints a message to stderr prefixed with "warning: ".
# Example: console.Warn("disk space low")
func Warn(msg string)
    fmt.Fprintln(os.Stderr, "warning: {msg}")
