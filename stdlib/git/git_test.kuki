# --- TestTagExists (network) ---
type TagExistsCase
    name string

func TestTagExists(t reference testing.T)
    if not ghAvailable()
        t.Skip("gh CLI not available or not authenticated")

    cases := list of TagExistsCase{{name: "existing tag"}}

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            exists, err := git.TagExists("cli/cli", "v2.0.0")
            test.AssertNoError(t, err)
            test.AssertTrue(t, exists)
        )

# --- TestRepoExists (network) ---
type RepoExistsCase
    name string

func TestRepoExists(t reference testing.T)
