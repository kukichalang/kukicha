# Tests for Kukicha Standard Library - Maps Package

petiole maps_test

import "stdlib/maps"
import "stdlib/slice"
import "testing"

# Test Keys, Values, and Contains helpers
func TestMapHelpers(t reference testing.T)
    # Maps package functions exist and are accessible
    # Detailed type compatibility testing requires maps of compatible types
    sample := map of any to any{"a" as any: "1" as any, "b" as any: "2" as any}
    keys := maps.Keys(sample)
    if len(keys) != 2
        t.Fatalf("Expected 2 keys, got {len(keys)}")
    if not slice.Contains(keys, "a")
        t.Errorf("Keys should include 'a'")

    values := maps.Values(sample)
    if len(values) != 2
        t.Fatalf("Expected 2 values, got {len(values)}")
    if not slice.Contains(values, "2")
        t.Errorf("Values should include '2'")

    if not maps.Contains(sample, "a")
        t.Errorf("Contains should return true for existing key")
    if maps.Contains(sample, "missing")
        t.Errorf("Contains should return false for missing key")

# --- TestHas ---
func TestHas(t reference testing.T)
    sample := map of any to any{"x" as any: "1" as any}
    if not maps.Has(sample, "x")
        t.Errorf("Has should return true for existing key")
    if maps.Has(sample, "missing")
        t.Errorf("Has should return false for missing key")

# --- TestMerge ---
func TestMerge(t reference testing.T)
    base := map of any to any{"a" as any: "1" as any, "b" as any: "2" as any}
    overlay := map of any to any{"b" as any: "99" as any, "c" as any: "3" as any}
    merged := maps.Merge(base, overlay)
    if len(merged) != 3
        t.Fatalf("Expected 3 keys, got {len(merged)}")
    if merged["a"] != "1"
        t.Errorf("Merge should keep base key 'a'")
    if merged["b"] != "99"
        t.Errorf("Merge should prefer overlay value for 'b'")
    if merged["c"] != "3"
        t.Errorf("Merge should include overlay key 'c'")

# --- TestSortedKeys ---
func TestSortedKeys(t reference testing.T)
    sample := map of any to any{"c" as any: "3" as any, "a" as any: "1" as any, "b" as any: "2" as any}
    keys := maps.SortedKeys(sample)
    if len(keys) != 3
        t.Fatalf("Expected 3 keys, got {len(keys)}")
    if keys[0] != "a"
        t.Errorf("Expected first key 'a', got '{keys[0]}'")
    if keys[1] != "b"
        t.Errorf("Expected second key 'b', got '{keys[1]}'")
    if keys[2] != "c"
        t.Errorf("Expected third key 'c', got '{keys[2]}'")

# --- TestFilter ---
func TestFilter(t reference testing.T)
    m := map of any to any{"a" as any: "1" as any, "b" as any: "2" as any, "c" as any: "3" as any}
    t.Run("filters by value", (t reference testing.T) =>
        result := maps.Filter(m, (k any, v any) => v != "1" as any)
        if len(result) != 2
            t.Errorf("Expected 2 entries, got {len(result)}")
        _, hasA := result["a"]
        if hasA
            t.Errorf("Key 'a' should have been filtered out")
    )
    t.Run("all pass", (t reference testing.T) =>
        result := maps.Filter(m, (k any, v any) => true)
        if len(result) != 3
            t.Errorf("Expected 3 entries, got {len(result)}")
    )
    t.Run("none pass", (t reference testing.T) =>
        result := maps.Filter(m, (k any, v any) => false)
        if len(result) != 0
            t.Errorf("Expected 0 entries, got {len(result)}")
    )

# --- TestMapValues ---
func TestMapValues(t reference testing.T)
    m := map of any to any{"x" as any: 1 as any, "y" as any: 2 as any}
    result := maps.MapValues(m, (v any) => v)
    t.Run("same number of keys", (t reference testing.T) =>
        if len(result) != 2
            t.Errorf("Expected 2 entries, got {len(result)}")
    )
    t.Run("keys preserved", (t reference testing.T) =>
        _, hasX := result["x"]
        if not hasX
            t.Errorf("Key 'x' should be present")
    )
    t.Run("does not modify original", (t reference testing.T) =>
        maps.MapValues(m, (v any) => "transformed" as any)
        if m["x"] != 1 as any
            t.Errorf("Original map should not be modified")
    )

# --- TestPick ---
func TestPick(t reference testing.T)
    m := map of any to any{"a" as any: "1" as any, "b" as any: "2" as any, "c" as any: "3" as any}
    t.Run("picks specified keys", (t reference testing.T) =>
        result := maps.Pick(m, list of any{"a" as any, "c" as any})
        if len(result) != 2
            t.Errorf("Expected 2 entries, got {len(result)}")
        if result["a"] != "1" as any
            t.Errorf("Expected value '1' for key 'a'")
        _, hasB := result["b"]
        if hasB
            t.Errorf("Key 'b' should not be in result")
    )
    t.Run("missing keys ignored", (t reference testing.T) =>
        result := maps.Pick(m, list of any{"a" as any, "z" as any})
        if len(result) != 1
            t.Errorf("Expected 1 entry, got {len(result)}")
    )

# --- TestOmit ---
func TestOmit(t reference testing.T)
    m := map of any to any{"a" as any: "1" as any, "b" as any: "2" as any, "c" as any: "3" as any}
    t.Run("omits specified keys", (t reference testing.T) =>
        result := maps.Omit(m, list of any{"b" as any})
        if len(result) != 2
            t.Errorf("Expected 2 entries, got {len(result)}")
        _, hasB := result["b"]
        if hasB
            t.Errorf("Key 'b' should have been omitted")
        if result["a"] != "1" as any
            t.Errorf("Expected value '1' for key 'a'")
    )
    t.Run("omit missing key is no-op", (t reference testing.T) =>
        result := maps.Omit(m, list of any{"z" as any})
        if len(result) != 3
            t.Errorf("Expected 3 entries, got {len(result)}")
    )
