# Kukicha Standard Library - MCP Server Wrapper

petiole mcp

import "context"
import "net/http"
import "stdlib/ctx" as ctxpkg
import "stdlib/json"
import "stdlib/string" as strpkg

import "github.com/modelcontextprotocol/go-sdk/mcp"

# ToolHandler is a callback for handling MCP tool invocations.
type ToolHandler func(map of string to any) (any, error)

# SchemaProperty represents a property in a JSON schema
type SchemaProperty
    Name string
    Type string
    Description string

# New creates a new MCP server with the given name and version.
# Example:
#   server := mcp.New("my-server", "1.0.0")
func New(name string, version string) reference mcp.Server
    return mcp.NewServer(reference of mcp.Implementation{Name: name, Version: version}, empty)

# Serve runs the server on the stdio transport (blocking).
# Usually called at the very end of func main().
# Example:
#   server |> mcp.Serve() onerr panic "{error}"
func Serve(server reference mcp.Server) error
    bg := ctxpkg.Background()
    return server.Run(ctxpkg.Value(bg), reference of mcp.StdioTransport{})

# Prop creates a new SchemaProperty
func Prop(name string, typ string, description string) SchemaProperty
    return {Name: name, Type: typ, Description: description}

# Schema creates a JSON schema object from a list of properties
func Schema(props list of SchemaProperty) map of string to any
    properties := make(map of string to any)
    for prop in props
        properties[prop.Name] = map of string to any{"type": prop.Type, "description": prop.Description}

    return map of string to any{"type": "object", "properties": properties}

# Required adds a list of required property names to a schema
func Required(schema any, names list of string) any
    result := schema
    schema |> switch as s
        when map of string to any
            s["required"] = names
            result = s

    return result

# TextResult creates a successful tool result containing the given text.
# Useful for returning strings directly to the AI.
func TextResult(text string) any
    return reference of mcp.CallToolResult{Content: list of mcp.Content{reference of mcp.TextContent{Text: text}}}

# ErrorResult creates an error tool result containing the given message.
func ErrorResult(msg string) any
    return reference of mcp.CallToolResult{
        Content: list of mcp.Content{reference of mcp.TextContent{Text: msg}},
        IsError: true,
    }

# Tool registers an MCP tool with the given handler.
# The handler receives parsed JSON arguments and returns a result.
# String and *mcp.CallToolResult results are handled directly;
# other types are JSON-serialized.
# Example:
#   server |> mcp.Tool("hello", "Say hello", schema, func(args) { return "Hi!", empty })
func Tool(server reference mcp.Server, name string, description string, schema any, handler ToolHandler)
    server.AddTool(reference of mcp.Tool{Name: name, Description: description, InputSchema: schema}, func(ctx context.Context, req reference mcp.CallToolRequest) (reference mcp.CallToolResult, error)
        args := make(map of string to any)
        if len(req.Params.Arguments) > 0
            unmarshalErr := json.Unmarshal(req.Params.Arguments, reference of args)
            if unmarshalErr != empty
                return empty, unmarshalErr
        res, handlerErr := handler(args)
        if handlerErr != empty
            return reference of mcp.CallToolResult{
                Content: list of mcp.Content{reference of mcp.TextContent{Text: handlerErr.Error()}},
                IsError: true,
            }, empty

        res |> switch as r
            when reference mcp.CallToolResult
                return r, empty
            when string
                return reference of mcp.CallToolResult{
                    Content: list of mcp.Content{reference of mcp.TextContent{Text: r}},
                }, empty

        data, _ := json.Marshal(res)
        return reference of mcp.CallToolResult{
            Content: list of mcp.Content{reference of mcp.TextContent{Text: string(data)}},
        }, empty
    )

# ToolSamplingHandler is a tool handler that receives a *ServerSession so it
# can invoke sampling (createMessage) on the connected AI client.
# Register it with ToolWithSampling.
type ToolSamplingHandler func(context.Context, reference ServerSession, map of string to any) (any, error)

# ServerSession wraps *mcp.ServerSession so tool handlers can call sampling
# without a direct dependency on the go-sdk.
type ServerSession
    inner reference mcp.ServerSession

# CreateMessage sends a sampling/createMessage request to the connected client
# and returns the AI-generated response. Use this inside a ToolWithSampling
# handler to get AI completions during tool execution.
func CreateMessage on ss reference ServerSession(ctx context.Context, params reference mcp.CreateMessageParams) (reference mcp.CreateMessageResult, error)
    return ss.inner.CreateMessage(ctx, params)

# CreateMessageWithTools sends a sampling request that includes tools and
# supports array content in the response (parallel tool_use blocks).
func CreateMessageWithTools on ss reference ServerSession(ctx context.Context, params reference mcp.CreateMessageWithToolsParams) (reference mcp.CreateMessageWithToolsResult, error)
    return ss.inner.CreateMessageWithTools(ctx, params)

# ToolWithSampling registers an MCP tool whose handler receives a *ServerSession
# for sampling. This is the sampling-capable analogue of Tool.
# Example:
#   mcp.ToolWithSampling(server, "chat", "Chat with the AI", schema,
#       func(ctx, session, args) {
#           msgs := []*mcp.SamplingMessage{{Role: "user", Content: &mcp.TextContent{Text: args["message"].(string)}}}
#           result, _ := session.CreateMessage(ctx, &mcp.CreateMessageParams{Messages: msgs, MaxTokens: 1024})
#           return result.Content.(*mcp.TextContent).Text, nil
#       })
func ToolWithSampling(server reference mcp.Server, name string, description string, schema any, handler ToolSamplingHandler)
    server.AddTool(reference of mcp.Tool{Name: name, Description: description, InputSchema: schema}, func(ctx context.Context, req reference mcp.CallToolRequest) (reference mcp.CallToolResult, error)
        args := make(map of string to any)
        if len(req.Params.Arguments) > 0
            unmarshalErr := json.Unmarshal(req.Params.Arguments, reference of args)
            if unmarshalErr != empty
                return empty, unmarshalErr
        ss := reference of ServerSession{inner: req.Session}
        res, handlerErr := handler(ctx, ss, args)
        if handlerErr != empty
            return reference of mcp.CallToolResult{
                Content: list of mcp.Content{reference of mcp.TextContent{Text: handlerErr.Error()}},
                IsError: true,
            }, empty

        res |> switch as r
            when reference mcp.CallToolResult
                return r, empty
            when string
                return reference of mcp.CallToolResult{
                    Content: list of mcp.Content{reference of mcp.TextContent{Text: r}},
                }, empty

        data, _ := json.Marshal(res)
        return reference of mcp.CallToolResult{
            Content: list of mcp.Content{reference of mcp.TextContent{Text: string(data)}},
        }, empty
    )

# Client is a wrapper around mcp.Client for creating MCP client sessions.
type Client
    inner reference mcp.Client

# NewClient creates a new MCP client with the given name and version.
func NewClient(name string, version string) reference Client
    inner := mcp.NewClient(reference of mcp.Implementation{Name: name, Version: version}, empty)
    return reference of Client{inner: inner}

# SamplingHandler handles a basic sampling/createMessage request from the
# connected MCP server. Set it via NewClientWithSampling.
type SamplingHandler func(context.Context, reference mcp.CreateMessageParams) (reference mcp.CreateMessageResult, error)

# SamplingWithToolsHandler handles a tool-enabled sampling/createMessage
# request. Set it via NewClientWithSamplingTools.
type SamplingWithToolsHandler func(context.Context, reference mcp.CreateMessageWithToolsParams) (reference mcp.CreateMessageWithToolsResult, error)

# NewClientWithSampling creates a new MCP client that advertises sampling
# support and handles sampling/createMessage requests from the server.
# Use this when the MCP server may call back into the client to generate AI
# completions (agentic tool loops).
# Example:
#   client := mcp.NewClientWithSampling("my-app", "1.0.0", func(ctx, params) { return myLLM.Complete(ctx, params) })
func NewClientWithSampling(name string, version string, handler SamplingHandler) reference Client
    opts := reference of mcp.ClientOptions{}
    opts.CreateMessageHandler = func(ctx context.Context, req reference mcp.CreateMessageRequest) (reference mcp.CreateMessageResult, error)
        return handler(ctx, req.Params)

    inner := mcp.NewClient(reference of mcp.Implementation{Name: name, Version: version}, opts)
    return reference of Client{inner: inner}

# NewClientWithSamplingTools creates a new MCP client that advertises
# sampling-with-tools support. The handler receives CreateMessageWithToolsParams
# and may return multiple content blocks (e.g. parallel tool_use blocks).
# Use this when the server may send tools in sampling requests.
func NewClientWithSamplingTools(name string, version string, handler SamplingWithToolsHandler) reference Client
    opts := reference of mcp.ClientOptions{}
    opts.CreateMessageWithToolsHandler = func(ctx context.Context, req reference mcp.CreateMessageWithToolsRequest) (reference mcp.CreateMessageWithToolsResult, error)
        return handler(ctx, req.Params)

    inner := mcp.NewClient(reference of mcp.Implementation{Name: name, Version: version}, opts)
    return reference of Client{inner: inner}

# Connect creates a new MCP client session using a streamable HTTP transport.
func Connect on c reference Client(ctx context.Context, endpoint string) (reference ClientSession, error)
    return c.ConnectWith(ctx, endpoint, empty)

# ConnectWith creates a new MCP client session using a custom http.Client.
# Pass a custom http.Client to inject authentication headers (e.g. via a custom RoundTripper).
# If httpClient is nil, the default http.Client is used.
func ConnectWith on c reference Client(ctx context.Context, endpoint string, httpClient reference http.Client) (reference ClientSession, error)
    transport := reference of mcp.StreamableClientTransport{Endpoint: endpoint, HTTPClient: httpClient}
    session := c.inner.Connect(ctx, transport, empty) onerr return empty, error "MCP connect to {endpoint} failed: {error}"
    return reference of ClientSession{inner: session}, empty

# ClientSession is a wrapper around mcp.ClientSession
type ClientSession
    inner reference mcp.ClientSession

# Close closes the MCP client session.
func Close on s reference ClientSession error
    return s.inner.Close()

# ListTools retrieves the available tools from the connected MCP server.
func ListTools on s reference ClientSession(ctx context.Context) (list of ClientTool, error)
    result := s.inner.ListTools(ctx, empty) onerr return empty list of ClientTool, error "MCP ListTools failed: {error}"
    tools := make(list of ClientTool, len(result.Tools))
    for i, t in result.Tools
        schema := empty map of string to any
        t.InputSchema |> switch as m
            when map of string to any
                schema = m

        tools[i] = ClientTool{Name: t.Name, Description: t.Description, InputSchema: schema}
    return tools, empty

# CallTool calls a specific tool by name with arguments.
# Use the Content field of the result for typed access to response items.
func CallTool on s reference ClientSession(ctx context.Context, params reference mcp.CallToolParams) (CallToolResult, error)
    result := s.inner.CallTool(ctx, params) onerr return {}, error "MCP CallTool \"{params.Name}\" failed: {error}"
    content := make(list of any, len(result.Content))
    for i, c in result.Content
        content[i] = c
    parts := make(list of string, 0)
    for _, c in result.Content
        c |> switch as v
            when reference mcp.TextContent
                parts = append(parts, v.Text)
            when reference mcp.ImageContent
                parts = append(parts, "[image: {v.MIMEType}]")
            otherwise
                data, _ := json.Marshal(c)
                parts = append(parts, data as string)

    text := strpkg.Join(parts, "\n")
    return {Text: text, IsError: result.IsError, Content: content}, empty

# ClientTool represents an MCP tool discovered from a server
type ClientTool
    Name string
    Description string
    InputSchema map of string to any

# CallToolResult represents the result of a tool call.
# Text is the concatenated text from all TextContent items.
# Content holds the raw response items; type-assert elements to *TextContent, *ImageContent, etc.
type CallToolResult
    Text string
    IsError bool
    Content list of any

# bearerTransport is an http.RoundTripper that injects a Bearer token into every request
type bearerTransport
    token string
    base http.RoundTripper

func RoundTrip on t reference bearerTransport(req reference http.Request) (reference http.Response, error)
    req.Header.Set("Authorization", "Bearer {t.token}")
    return t.base.RoundTrip(req)

# Connect creates a new MCP client and connects to the given streamable HTTP endpoint URL.
func Connect(ctx context.Context, endpoint string) (reference ClientSession, error)
    return ConnectWithClient(ctx, endpoint, empty)

# BearerConnect creates a new MCP client and connects with Bearer token authentication.
# The token is sent as an Authorization header on every request to the MCP server.
# Example: session := mcp.BearerConnect(ctx, url, apiKey) onerr return
func BearerConnect(ctx context.Context, endpoint string, token string) (reference ClientSession, error)
    httpClient := reference of http.Client{Transport: reference of bearerTransport{token: token, base: http.DefaultTransport}}
    return ConnectWithClient(ctx, endpoint, httpClient)

# ConnectWithClient creates a new MCP client and connects using the provided http.Client.
# Pass a custom http.Client to inject authentication headers (e.g. via a custom RoundTripper).
# If httpClient is nil, the default http.Client is used.
func ConnectWithClient(ctx context.Context, endpoint string, httpClient reference http.Client) (reference ClientSession, error)
    client := mcp.NewClient(reference of mcp.Implementation{Name: "kukicha-mcp-client", Version: "1.0.0"}, empty)
    transport := reference of mcp.StreamableClientTransport{Endpoint: endpoint, HTTPClient: httpClient}
    session := client.Connect(ctx, transport, empty) onerr return empty, error "MCP connect to {endpoint} failed: {error}"
    return reference of ClientSession{inner: session}, empty

# Close closes the MCP client session.
func Close(session reference ClientSession) error
    return session.inner.Close()

# ListTools retrieves the available tools from the connected MCP server.
func ListTools(ctx context.Context, session reference ClientSession) (list of ClientTool, error)
    return session.ListTools(ctx)

# CallTool calls a specific tool by name with arguments.
func CallTool(ctx context.Context, session reference ClientSession, name string, args map of string to any) (CallToolResult, error)
    return session.CallTool(ctx, reference of mcp.CallToolParams{Name: name, Arguments: args})
