# Tests for Kukicha Standard Library - Random Package

petiole random_test

import "stdlib/random"
import "stdlib/test"
import "testing"

# --- TestRandomStringLength ---
type LengthCase
    name string

func TestRandomStringLength(t reference testing.T)
    cases := list of LengthCase{{name: "lengths"}}

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            s := random.String(10)
            test.AssertEqual(t, len(s), 10)

            zero := random.String(0)
            test.AssertEqual(t, zero, "")

            alpha := random.Alphanumeric(5)
            test.AssertEqual(t, len(alpha), 5)
        )

# --- TestRandomInt ---
func TestRandomInt(t reference testing.T)
    for _ from 0 to 100
        v := random.Int(5, 10)
        if v < 5 or v >= 10
            t.Errorf("random.Int(5, 10) = %d, out of range", v)

    # min == max collapses to min
    test.AssertEqual(t, random.Int(7, 7), 7)

    # min > max collapses to min
    test.AssertEqual(t, random.Int(10, 5), 10)

# --- TestRandomFloat ---
func TestRandomFloat(t reference testing.T)
    for _ from 0 to 100
        v := random.Float(1.0, 2.0)
        if v < 1.0 or v >= 2.0
            t.Errorf("random.Float(1.0, 2.0) = %f, out of range", v)

    # min == max collapses to min
    test.AssertEqual(t, random.Float(3.5, 3.5), 3.5)

    # min > max collapses to min
    test.AssertEqual(t, random.Float(2.0, 1.0), 2.0)
