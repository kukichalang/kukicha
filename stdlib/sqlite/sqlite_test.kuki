# --- TestOpenWith ---
type OpenWithCase
    name string

func TestOpenWith(t reference testing.T)
    cases := list of OpenWithCase{{name: "open with custom pragmas"}}

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            dir := t.TempDir()
            path := filepath.Join(dir, "test.db")
            pragmas := map of string to string{
                "journal_mode": "WAL",
                "busy_timeout": "5000",
            }

            pool := sqlite.OpenWith(path, pragmas) onerr panic "open: {error}"
            defer db.Close(pool)

            timeout := sqlite.Pragma(pool, "busy_timeout") onerr panic "pragma: {error}"
            test.AssertEqual(t, timeout, "5000")
        )

# --- TestPragma ---
type PragmaCase
    name string
    pragma string
    setValue string

func TestPragma(t reference testing.T)
    cases := list of PragmaCase{
        PragmaCase{name: "get and set cache_size", pragma: "cache_size", setValue: "-4000"},
    }

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := sqlite.OpenMemory() onerr panic "open: {error}"
            defer db.Close(pool)

            sqlite.SetPragma(pool, tc.pragma, tc.setValue) onerr panic "set: {error}"
            got := sqlite.Pragma(pool, tc.pragma) onerr panic "get: {error}"
            test.AssertEqual(t, got, tc.setValue)
        )

# --- TestPragmaInvalidName ---
type PragmaInvalidCase
    name string
    pragma string

func TestPragmaInvalidName(t reference testing.T)
    cases := list of PragmaInvalidCase{
        PragmaInvalidCase{name: "reject injection attempt", pragma: "cache_size; DROP TABLE users"},
    }

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := sqlite.OpenMemory() onerr panic "open: {error}"
            defer db.Close(pool)

            _, err := sqlite.Pragma(pool, tc.pragma)
            test.AssertError(t, err)
        )

# --- TestSetPragmaInvalidValue ---

func TestSetPragmaInvalidValue(t reference testing.T)
    pool := sqlite.OpenMemory() onerr panic "open: {error}"
    defer db.Close(pool)

    err := sqlite.SetPragma(pool, "cache_size", "-4000; DROP TABLE users")
    test.AssertError(t, err)

    err2 := sqlite.SetPragma(pool, "journal_mode", "WAL; DROP TABLE users")
    test.AssertError(t, err2)

    err3 := sqlite.SetPragma(pool, "cache_size", "")
    test.AssertError(t, err3)

    # Valid values should still work
    err4 := sqlite.SetPragma(pool, "cache_size", "-64000")
    test.AssertNoError(t, err4)

    err5 := sqlite.SetPragma(pool, "journal_mode", "WAL")
    test.AssertNoError(t, err5)

# --- TestTables ---
type TablesCase
    name string
    createSQL list of string
    wantLen int

func TestTables(t reference testing.T)
    cases := list of TablesCase{
        TablesCase{
        name: "list created tables",
        createSQL: list of string{
        "CREATE TABLE alpha (id INTEGER PRIMARY KEY)",
        "CREATE TABLE beta (id INTEGER PRIMARY KEY)",
    },
        wantLen: 2,
    },
        TablesCase{name: "empty database", createSQL: empty list of string, wantLen: 0},
    }

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := sqlite.OpenMemory() onerr panic "open: {error}"
            defer db.Close(pool)
            for _, sql in tc.createSQL
                db.Exec(pool, sql) onerr panic "create: {error}"

            tables := sqlite.Tables(pool) onerr panic "tables: {error}"
            test.AssertEqual(t, len(tables), tc.wantLen)
            if tc.wantLen == 2
                test.AssertEqual(t, tables[0], "alpha")
                test.AssertEqual(t, tables[1], "beta")
        )

# --- TestTableExists ---
type TableExistsCase
    name string
    table string
    want bool

func TestTableExists(t reference testing.T)
    cases := list of TableExistsCase{
        TableExistsCase{name: "existing table", table: "users", want: true},
        TableExistsCase{name: "missing table", table: "nonexistent", want: false},
    }

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := setupTestDB(t)
            defer db.Close(pool)

            exists := sqlite.TableExists(pool, tc.table) onerr panic "exists: {error}"
            test.AssertEqual(t, exists, tc.want)
        )

# --- TestIntegrityCheck ---

func TestIntegrityCheck(t reference testing.T)
    pool := setupTestDB(t)
    defer db.Close(pool)

    err := sqlite.IntegrityCheck(pool)
    test.AssertNoError(t, err)

# --- TestForeignKeyEnforcement ---

func TestForeignKeyEnforcement(t reference testing.T)
    pool := sqlite.OpenMemory() onerr panic "open: {error}"
    defer db.Close(pool)

    db.Exec(pool, "CREATE TABLE parents (id INTEGER PRIMARY KEY)") onerr panic "create: {error}"
    db.Exec(pool, "CREATE TABLE children (id INTEGER PRIMARY KEY, parent_id INTEGER REFERENCES parents(id))") onerr panic "create: {error}"

    # Should fail: no parent with id=999 exists
    _, err := db.Exec(pool, "INSERT INTO children (parent_id) VALUES (999)")
    test.AssertError(t, err)

# --- TestVacuum ---
type VacuumCase
    name string

func TestVacuum(t reference testing.T)
    cases := list of VacuumCase{{name: "vacuum succeeds"}}

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := setupTestDB(t)
            defer db.Close(pool)

            err := sqlite.Vacuum(pool)
            test.AssertNoError(t, err)
        )

# --- TestBackup ---
type BackupCase
    name string

func TestBackup(t reference testing.T)
    cases := list of BackupCase{{name: "backup and verify"}}

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := setupTestDB(t)
            defer db.Close(pool)

            dir := t.TempDir()
            backupPath := filepath.Join(dir, "backup.db")
            sqlite.Backup(pool, backupPath) onerr panic "backup: {error}"

            _, statErr := os.Stat(backupPath)
            test.AssertNoError(t, statErr)

            backupPool := sqlite.Open(backupPath) onerr panic "open backup: {error}"
            defer db.Close(backupPool)

            result := db.Query(backupPool, "SELECT id, name, email FROM users ORDER BY id")
                |> db.ScanAll(empty list of User) onerr panic "scan: {error}"

            users := result.(list of User)
            test.AssertEqual(t, len(users), 2)
            test.AssertEqual(t, users[0].Name, "Alice")
        )

# Verify backup exists

