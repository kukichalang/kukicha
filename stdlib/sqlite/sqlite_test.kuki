# Tests for Kukicha Standard Library - SQLite Package

petiole sqlite_test

import "fmt"
import "os"
import "path/filepath"
import "stdlib/db"
import "stdlib/sqlite"
import "stdlib/test"
import "strings" as strpkg
import "testing"

type User
    Id int64 as "id"
    Name string as "name"
    Email string as "email"

func setupTestDB(t reference testing.T) db.Pool
    pool := sqlite.OpenMemory() onerr panic "open failed: {error}"
    db.Exec(pool, "CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT)") onerr panic "create failed: {error}"
    db.Exec(pool, "INSERT INTO users (name, email) VALUES (?, ?)", "Alice", "alice@example.com") onerr panic "insert failed: {error}"
    db.Exec(pool, "INSERT INTO users (name, email) VALUES (?, ?)", "Bob", "bob@example.com") onerr panic "insert failed: {error}"
    return pool

# --- TestOpenMemory ---
type OpenMemoryCase
    name string

func TestOpenMemory(t reference testing.T)
    cases := list of OpenMemoryCase{{name: "open in-memory and query"}}

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := setupTestDB(t)
            defer db.Close(pool)
            result := db.Query(pool, "SELECT id, name, email FROM users ORDER BY id")
                |> db.ScanAll(empty list of User) onerr panic "scan: {error}"

            users := result.(list of User)
            test.AssertEqual(t, len(users), 2)
            test.AssertEqual(t, users[0].Name, "Alice")
            test.AssertEqual(t, users[1].Name, "Bob")
        )

# --- TestOpen ---
type OpenCase
    name string

func TestOpen(t reference testing.T)
    cases := list of OpenCase{{name: "open file database with WAL"}}

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            dir := t.TempDir()
            path := filepath.Join(dir, "test.db")
            pool := sqlite.Open(path) onerr panic "open: {error}"
            defer db.Close(pool)

            db.Exec(pool, "CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT)") onerr panic "create: {error}"
            db.Exec(pool, "INSERT INTO items (name) VALUES (?)", "widget") onerr panic "insert: {error}"

            mode := sqlite.Pragma(pool, "journal_mode") onerr panic "pragma: {error}"
            test.AssertEqual(t, mode, "wal")

            fk := sqlite.Pragma(pool, "foreign_keys") onerr panic "pragma: {error}"
            test.AssertEqual(t, fk, "1")

            timeout := sqlite.Pragma(pool, "busy_timeout") onerr panic "pragma: {error}"
            test.AssertEqual(t, timeout, "5000")
        )

