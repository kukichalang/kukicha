# --- TestCreateFunctionBool ---
type CreateFunctionBoolCase
    name string
    values list of string
    wantCount int64

func TestCreateFunctionBool(t reference testing.T)
    cases := list of CreateFunctionBoolCase{
        {name: "filter non-empty strings", values: list of string{"hi", "", "there", ""}, wantCount: 2},
    }

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := sqlite.OpenMemory() onerr panic "open: {error}"
            defer db.Close(pool)

            nonEmptyFn := func(args list of string) bool
                return len(args[0]) > 0

            sqlite.CreateFunctionBool(pool, "is_nonempty", 1, nonEmptyFn) onerr panic "create function: {error}"

            db.Exec(pool, "CREATE TABLE vals (v TEXT)") onerr panic "create: {error}"
            for _, val in tc.values
                db.Exec(pool, "INSERT INTO vals (v) VALUES (?)", val) onerr panic "insert: {error}"

            count := db.Count(pool, "SELECT COUNT(*) FROM vals WHERE is_nonempty(v)") onerr panic "count: {error}"
            test.AssertEqual(t, count, tc.wantCount)
        )

# --- TestCreateBlobFunction ---
type CreateBlobFunctionCase
    name string
    input string
    want string

func TestCreateBlobFunction(t reference testing.T)
    cases := list of CreateBlobFunctionCase{
        {name: "reverse bytes", input: "010203", want: "030201"},
        {name: "single byte", input: "FF", want: "FF"},
    }

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := sqlite.OpenMemory() onerr panic "open: {error}"
            defer db.Close(pool)

            reverseFn := func(args list of list of byte) list of byte
                b := args[0]
                out := make(list of byte, len(b))
                for i from 0 to len(b)
                    out[i] = b[len(b) - 1 - i]
                return out

            sqlite.CreateBlobFunction(pool, "reverse_blob", 1, reverseFn) onerr panic "create function: {error}"

            rawDB := db.RawDB(pool)
            row := rawDB.QueryRow(fmt.Sprintf("SELECT hex(reverse_blob(X'%s'))", tc.input))
            result := ""
            row.Scan(reference of result) onerr panic "scan: {error}"
            test.AssertEqual(t, result, tc.want)
        )

# --- TestCreateBlobFunctionFloat ---
type CreateBlobFunctionFloatCase
    name string
    input string
    want float64

func TestCreateBlobFunctionFloat(t reference testing.T)
    cases := list of CreateBlobFunctionFloatCase{
        {name: "sum of bytes", input: "010203", want: 6.0},
        {name: "single byte", input: "0A", want: 10.0},
        {name: "empty blob", input: "", want: 0.0},
    }

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := sqlite.OpenMemory() onerr panic "open: {error}"
            defer db.Close(pool)

            sumFn := func(args list of list of byte) float64
                total := 0.0
                for _, b in args[0]
                    total = total + b as float64
                return total

            sqlite.CreateBlobFunctionFloat(pool, "blob_sum", 1, sumFn) onerr panic "create function: {error}"

            rawDB := db.RawDB(pool)
            row := rawDB.QueryRow(fmt.Sprintf("SELECT blob_sum(X'%s')", tc.input))
            result := 0.0
            row.Scan(reference of result) onerr panic "scan: {error}"
            test.AssertEqual(t, result, tc.want)
        )

# --- TestDump ---
type DumpCase
    name string

func TestDump(t reference testing.T)
    cases := list of DumpCase{{name: "dump contains schema and data"}}

    for tc in cases
        t.Run(tc.name, (t reference testing.T) =>
            pool := setupTestDB(t)
            defer db.Close(pool)

            sql := sqlite.Dump(pool) onerr panic "dump: {error}"
            test.AssertTrue(t, strpkg.Contains(sql, "CREATE TABLE"))
            test.AssertTrue(t, strpkg.Contains(sql, "INSERT INTO"))
            test.AssertTrue(t, strpkg.Contains(sql, "Alice"))
            test.AssertTrue(t, strpkg.Contains(sql, "Bob"))
        )

# --- TestAddNotNull ---

func TestAddNotNull(t reference testing.T)
    t.Run("add NOT NULL to column", (t reference testing.T) =>
        pool := sqlite.OpenMemory() onerr panic "open: {error}"
        defer db.Close(pool)

        db.Exec(pool, "CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT)") onerr panic "create: {error}"
        db.Exec(pool, "INSERT INTO items (name) VALUES (?)", "widget") onerr panic "insert: {error}"

        sqlite.AddNotNull(pool, "items", "name") onerr panic "add not null: {error}"

        _, err := db.Exec(pool, "INSERT INTO items (name) VALUES (NULL)")
        test.AssertError(t, err)
    )

# Inserting NULL should now fail.

# --- TestDropNotNull ---

func TestDropNotNull(t reference testing.T)
    t.Run("drop NOT NULL from column", (t reference testing.T) =>
        pool := sqlite.OpenMemory() onerr panic "open: {error}"
        defer db.Close(pool)

        db.Exec(pool, "CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT NOT NULL)") onerr panic "create: {error}"

        sqlite.DropNotNull(pool, "items", "name") onerr panic "drop not null: {error}"

        db.Exec(pool, "INSERT INTO items (name) VALUES (NULL)") onerr panic "insert null: {error}"
    )

# Inserting NULL should now succeed.

# --- TestAddCheck ---

func TestAddCheck(t reference testing.T)
    t.Run("add CHECK constraint", (t reference testing.T) =>
        pool := sqlite.OpenMemory() onerr panic "open: {error}"
        defer db.Close(pool)

        db.Exec(pool, "CREATE TABLE ages (id INTEGER PRIMARY KEY, age INTEGER)") onerr panic "create: {error}"

        sqlite.AddCheck(pool, "ages", "age >= 0") onerr panic "add check: {error}"

        _, err := db.Exec(pool, "INSERT INTO ages (age) VALUES (?)", -1)
        test.AssertError(t, err)

        db.Exec(pool, "INSERT INTO ages (age) VALUES (?)", 25) onerr panic "insert: {error}"
    )

# Inserting a negative age should now fail.

# Inserting a valid age should succeed.

# --- TestDropCheck ---

func TestDropCheck(t reference testing.T)
    t.Run("drop named CHECK constraint", (t reference testing.T) =>
        pool := sqlite.OpenMemory() onerr panic "open: {error}"
        defer db.Close(pool)

        db.Exec(pool, "CREATE TABLE ages (id INTEGER PRIMARY KEY, age INTEGER, CONSTRAINT age_positive CHECK (age >= 0))") onerr panic "create: {error}"

        _, err := db.Exec(pool, "INSERT INTO ages (age) VALUES (?)", -1)
        test.AssertError(t, err)

        sqlite.DropCheck(pool, "ages", "age_positive") onerr panic "drop check: {error}"

        db.Exec(pool, "INSERT INTO ages (age) VALUES (?)", -1) onerr panic "insert: {error}"
    )

# Should fail with negative age.

# Inserting a negative age should now succeed.

# --- TestAddNotNullInvalidName ---

func TestAddNotNullInvalidName(t reference testing.T)
    t.Run("reject invalid names", (t reference testing.T) =>
        pool := sqlite.OpenMemory() onerr panic "open: {error}"
        defer db.Close(pool)

        err := sqlite.AddNotNull(pool, "table; DROP TABLE users", "col")
        test.AssertError(t, err)

        err2 := sqlite.DropNotNull(pool, "ok", "col; DROP TABLE users")
        test.AssertError(t, err2)
    )

# --- TestAddCheckInvalid ---

func TestAddCheckInvalid(t reference testing.T)
    t.Run("reject empty expression", (t reference testing.T) =>
        pool := sqlite.OpenMemory() onerr panic "open: {error}"
        defer db.Close(pool)

        err := sqlite.AddCheck(pool, "t", "")
        test.AssertError(t, err)
    )

# --- TestReindexExpressions ---

func TestReindexExpressions(t reference testing.T)
    t.Run("reindex expressions succeeds", (t reference testing.T) =>
        pool := sqlite.OpenMemory() onerr panic "open: {error}"
        defer db.Close(pool)

        db.Exec(pool, "CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT)") onerr panic "create: {error}"
        db.Exec(pool, "CREATE INDEX idx_name_lower ON items (lower(name))") onerr panic "index: {error}"
        db.Exec(pool, "INSERT INTO items (name) VALUES (?)", "Hello") onerr panic "insert: {error}"

        sqlite.ReindexExpressions(pool) onerr panic "reindex: {error}"

        rawDB := db.RawDB(pool)
        row := rawDB.QueryRow("SELECT name FROM items WHERE lower(name) = ?", "hello")
        result := ""
        row.Scan(reference of result) onerr panic "scan: {error}"
        test.AssertEqual(t, result, "Hello")
    )
