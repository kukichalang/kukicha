petiole test

import "fmt"
import "reflect"
import "testing"

func AssertEqual(t reference testing.T, got any, want any, many msgAndArgs any)
    t.Helper()
    if not reflect.DeepEqual(got, want)
        prefix := ""
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v: ", msgAndArgs[0])
        t.Errorf("%sexpected %v, got %v", prefix, want, got)

func AssertTrue(t reference testing.T, condition bool, many msgAndArgs any)
    t.Helper()
    if not condition
        prefix := "expected true"
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v", msgAndArgs[0])
        t.Errorf("%s", prefix)

func AssertFalse(t reference testing.T, condition bool, many msgAndArgs any)
    t.Helper()
    if condition
        prefix := "expected false"
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v", msgAndArgs[0])
        t.Errorf("%s", prefix)

func AssertNoError(t reference testing.T, err error, many msgAndArgs any)
    t.Helper()
    if err isnt empty
        prefix := ""
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v: ", msgAndArgs[0])
        t.Errorf("%sunexpected error: %v", prefix, err)

func AssertError(t reference testing.T, err error, many msgAndArgs any)
    t.Helper()
    if err equals empty
        prefix := "expected an error, got nil"
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v", msgAndArgs[0])
        t.Errorf("%s", prefix)

func AssertNotEmpty(t reference testing.T, val any, many msgAndArgs any)
    t.Helper()
    if val equals empty
        prefix := "expected non-empty value, got nil"
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v", msgAndArgs[0])
        t.Errorf("%s", prefix)
        return
    v := reflect.ValueOf(val)
    if v.IsZero()
        prefix := "expected non-empty value, got zero value"
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v", msgAndArgs[0])
        t.Errorf("%s", prefix)

func AssertNil(t reference testing.T, val any, many msgAndArgs any)
    t.Helper()
    if val isnt empty
        prefix := "expected nil"
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v", msgAndArgs[0])
        t.Errorf("%s: got %v", prefix, val)

func AssertNotNil(t reference testing.T, val any, many msgAndArgs any)
    t.Helper()
    if val equals empty
        prefix := "expected non-nil value"
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v", msgAndArgs[0])
        t.Errorf("%s", prefix)

func AssertNotEqual(t reference testing.T, got any, want any, many msgAndArgs any)
    t.Helper()
    if reflect.DeepEqual(got, want)
        prefix := ""
        if len(msgAndArgs) > 0
            prefix = fmt.Sprintf("%v: ", msgAndArgs[0])
        t.Errorf("%sexpected values to differ, but both are %v", prefix, got)
